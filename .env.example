# ============================================================================
#  Copy this file to ".env.local" and fill in the values. All services below
#  have a FREE tier. The app still builds & runs with these left blank — auth,
#  reviews and real payments just stay in their "demo" state until added.
# ============================================================================

# --- Supabase (free) -> https://supabase.com -------------------------------
# Dashboard → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Admin dashboard (/admin) ----------------------------------------------
# Comma-separated emails allowed into /admin (e.g. you@email.com)
NEXT_PUBLIC_ADMIN_EMAILS=
# Service-role key — SERVER ONLY, lets the admin read all orders.
# Supabase → Project Settings → API Keys → "service_role" secret. Keep private!
SUPABASE_SERVICE_ROLE_KEY=

# --- Razorpay (free test mode) -> https://razorpay.com ----------------------
# Dashboard → Settings → API Keys → Generate Test Key
# These are SERVER-ONLY. Never expose the secret to the browser.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
